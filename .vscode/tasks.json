{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "swift-build",
            "type": "shell",
            "command": "swift build",
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "swift-build-release",
            "type": "shell",
            "command": "swift build -c release"
        },
        {
            "label": "swift-run",
            "type": "shell",
            "command": "swift run",
            "group": { "kind": "test", "isDefault": true }
        }
    ]
}
